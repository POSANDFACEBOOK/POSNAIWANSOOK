VITE_SUPA_URL="https://<your-project-ref>.supabase.co"
VITE_SUPA_ANON_KEY="<your-supabase-anon-key>"

# SlipTrack ingest token — server-side only (no VITE_ prefix on purpose).
# Used by /api/sliptrack-push to forward confirmed POs to SlipTrack.
# Set this in Vercel → Settings → Environment Variables (Production + Preview).
SLIPTRACK_API_KEY="<your-sliptrack-bearer-token>"
